# Groq (recommended for cloud): get a key at https://console.groq.com/
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Optional: local LM Studio when GROQ_API_KEY is empty
# LM_STUDIO_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=qwen2.5-3b-instruct

# Embeddings (768-d nomic by default, downloaded/cached on first run)
# Leave HTTP URL unset on Render to use bundled SentenceTransformer.
# EMBEDDING_HTTP_URL=http://127.0.0.1:1234/v1/embeddings
# EMBEDDING_HTTP_MODEL=nomic-embed-text-v1.5
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
